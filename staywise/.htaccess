# Disable directory listings
Options -Indexes

# Basic security headers (can be overridden in PHP if needed)
<IfModule mod_headers.c>
	Header always set X-Content-Type-Options "nosniff"
	Header always set X-Frame-Options "SAMEORIGIN"
	Header always set Referrer-Policy "strict-origin-when-cross-origin"
	Header always set X-XSS-Protection "0"
	# Minimal CSP: disallow inline scripts by default; adjust as your app needs
	Header set Content-Security-Policy "default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https:; script-src 'self' 'unsafe-inline' https:; font-src 'self' https: data:; connect-src 'self' https:; frame-ancestors 'self';"
</IfModule>

# Block access to sensitive files
<FilesMatch "\.(env|ini|log|sql|bak|config|sh|bat)$">
	Require all denied
</FilesMatch>
